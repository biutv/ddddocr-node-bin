{
  "name": "ocr-bin",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "node index.js",
    "build:debug": "pkg --public --options experimental-require-module --debug .",
    "build:win": "pkg --public --target node20-win-x64,node20-win-arm64 --options experimental-require-module .",
    "build:mac": "pkg --public --target node20-macos-x64,node20-macos-arm64 --options experimental-require-module .",
    "build:linux": "pkg --public --target node20-linux-x64,node20-linux-arm64 --options experimental-require-module ."
  },
  "dependencies": {
    "body-parser": "^2.2.0",
    "ddddocr-node": "^1.1.0",
    "express": "^5.1.0",
    "onnxruntime-node": "^1.22.0-rev",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.5.1",
    "patch-package": "^8.0.0"
  },
  "pkg": {
    "assets": [
      "node_modules/@jimp/**/*",
      "node_modules/@tensorflow/tfjs-node/**/*",
      "node_modules/ddddocr-node/onnx/*",
      "node_modules/onnxruntime-node/bin/napi-v3/*/*/onnxruntime.node"
    ],
    "scripts": [],
    "patches": {},
    "targets": [
      "node20-win-x64",
      "node20-win-arm64",
      "node20-macos-arm64",
      "node20-macos-x64",
      "node20-linux-arm64",
      "node20-linux-x64"
    ],
    "outputPath": "dist"
  }
}
