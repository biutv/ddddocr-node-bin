{
  "name": "ocr-bin",
  "version": "1.0.1",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev": "node index.js",
    "build": "node scripts/build.js",
    "build:win": "pkg index.js --target node20-win-x64,node20-win-arm64 --compress GZip --options --max-old-space-size=8192 .",
    "build:mac": "pkg index.js --target node20-macos-x64,node20-macos-arm64 --compress GZip --options --max-old-space-size=8192 .",
    "build:linux": "pkg index.js --target node20-linux-x64,node20-linux-arm64 --compress GZip --options --max-old-space-size=8192 ."
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "ddddocr-node": "2.2.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.1"
  },
  "pkg": {
    "assets": [
      "node_modules/@jimp/**/*",
      "node_modules/@tensorflow/**/*",
      "node_modules/ddddocr-node/onnx/*",
      "node_modules/onnxruntime-node/bin/**/*"
    ],
    "scripts": [],
    "patches": {},
    "targets": [],
    "outputPath": "dist"
  }
}
