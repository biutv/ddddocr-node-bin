{
  "name": "ocr-bin",
  "version": "1.0.5",
  "type": "commonjs",
  "main": "index.js",
  "homepage": "https://github.com/Hiram-Wong/ddddocr-node-bin",
  "scripts": {
    "dev": "node index.js",
    "build": "node scripts/build.js",
    "build:win:x64": "node scripts/build.js --platform win --arch x64",
    "build:win:arm64": "node scripts/build.js --platform win --arch arm64",
    "build:mac:x64": "node scripts/build.js --platform macos --arch x64",
    "build:mac:arm64": "node scripts/build.js --platform macos --arch arm64",
    "build:linux:x64": "node scripts/build.js --platform linux --arch x64",
    "build:linux:arm64": "node scripts/build.js --platform linux --arch arm64",
    "build:win": "node scripts/build.js --platform win",
    "build:mac": "node scripts/build.js --platform macos",
    "build:linux": "node scripts/build.js --platform linux"
  },
  "dependencies": {
    "@techstark/opencv-js": "^4.12.0-release.1",
    "body-parser": "^2.2.2",
    "ddddocr-node": "2.2.0",
    "express": "^5.2.1",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.2"
  },
  "pkg": {
    "assets": [
      "node_modules/@jimp/**/*",
      "node_modules/@tensorflow/**/*",
      "node_modules/ddddocr-node/onnx/*",
      "node_modules/onnxruntime-node/bin/**/*"
    ],
    "scripts": [],
    "patches": {},
    "targets": [
      "node24-win-x64",
      "node24-win-arm64",
      "node20-macos-x64",
      "node20-macos-arm64",
      "node20-linux-x64",
      "node20-linux-arm64"
    ],
    "outputPath": "dist"
  }
}
